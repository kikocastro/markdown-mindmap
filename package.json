{
  "name": "notes-mindmap",
  "version": "0.1.0",
  "description": "Configurable mind maps / leveled trees from note frontmatter links, for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run typecheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "obsidian-plugin"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "builtin-modules": "5.3.0",
    "esbuild": "0.28.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "obsidian": "1.13.1",
    "prettier": "^3.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
